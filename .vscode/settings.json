{
  // ─── PHP ───────────────────────────────────────────────────────────────────
  "php.validate.executablePath": "C:/laragon/bin/php/php8.4.4/php.exe",
  "intelephense.environment.phpVersion": "8.4.0",
  "intelephense.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/vendor/{,*/}Tests/**",
    "**/vendor/{,*/}tests/**",
    "**/vendor/bin/**"
  ],
  "intelephense.stubs": [
    "apache", "bcmath", "bz2", "calendar", "com_dotnet", "Core", "ctype",
    "curl", "date", "dba", "dom", "enchant", "exif", "FFI", "fileinfo",
    "filter", "fpm", "ftp", "gd", "gettext", "gmp", "hash", "iconv",
    "imap", "intl", "json", "ldap", "libxml", "mbstring", "meta",
    "mysqli", "oci8", "odbc", "openssl", "pcntl", "pcre", "PDO",
    "pdo_ibm", "pdo_mysql", "pdo_pgsql", "pdo_sqlite", "pgsql", "Phar",
    "posix", "pspell", "random", "readline", "Reflection", "regex",
    "session", "shmop", "SimpleXML", "snmp", "soap", "sockets", "sodium",
    "SPL", "sqlite3", "standard", "superglobals", "sysvmsg", "sysvsem",
    "sysvshm", "tidy", "tokenizer", "xml", "xmlreader", "xmlrpc",
    "xmlwriter", "xsl", "Zend OPcache", "zip", "zlib", "redis"
  ],
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "editor.formatOnSave": true
  },

  // ─── Vue / Inertia ─────────────────────────────────────────────────────────
  "vue.server.hybridMode": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar",
    "editor.formatOnSave": true
  },

  // ─── TypeScript ────────────────────────────────────────────────────────────
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.preferences.importModuleSpecifier": "relative",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ─── Tailwind CSS ──────────────────────────────────────────────────────────
  "tailwindCSS.includeLanguages": {
    "vue": "html",
    "blade": "html"
  },
  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.files.exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/vendor/**"
  ],

  // ─── Editor — RTL & Arabic ─────────────────────────────────────────────────
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.renderControlCharacters": false,
  // Blade files contain Arabic strings — disable aggressive validation
  "files.associations": {
    "*.blade.php": "blade",
    "*.md.md": "markdown"
  },

  // ─── Editor — General ──────────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [120],
  "editor.wordWrap": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.formatOnPaste": false,
  "editor.suggest.preview": true,

  // ─── Files ─────────────────────────────────────────────────────────────────
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/vendor": true,
    "**/.DS_Store": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
    "**/public/build": true,
    "**/storage": true
  },

  // ─── Emmet ─────────────────────────────────────────────────────────────────
  "emmet.includeLanguages": {
    "vue": "html",
    "blade": "html"
  },

  // ─── Laravel Pint (PHP formatter) ──────────────────────────────────────────
  "laravel-pint.enable": true,

  // ─── ESLint ────────────────────────────────────────────────────────────────
  "eslint.validate": ["javascript", "typescript", "vue"],
  "eslint.workingDirectories": [{ "mode": "auto" }],

  // ─── Extensions recommended ────────────────────────────────────────────────
  "extensions.ignoreRecommendations": false
}
